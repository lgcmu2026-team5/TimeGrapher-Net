<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TimeGrapher.App.Views.MainWindow"
        Title="TimeGrapher"
        Icon="/Assets/App/AppIcon-256.png"
        Width="1280" Height="750"
        MinWidth="900" MinHeight="560">
  <Grid RowDefinitions="36,*" Background="{DynamicResource SurfaceBgBrush}">
    <Border Grid.Row="0"
            Background="{DynamicResource SurfaceBgBrush}"
            BorderBrush="{DynamicResource ChromeBorderBrush}"
            BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="*,Auto">
        <Grid Grid.Column="0"
              ColumnDefinitions="Auto,Auto,*"
              Background="Transparent"
              PointerPressed="OnTitleBarPointerPressed">
          <Border Grid.Column="0"
                  Background="Transparent">
            <Image Source="/Assets/App/AppIcon-256.png"
                   Width="26"
                   Height="26"
                   Margin="10,0,8,0"
                   VerticalAlignment="Center" />
          </Border>
          <TextBlock Name="AppTitleText" Grid.Column="1"
                     Text="TimeGrapher"
                     VerticalAlignment="Center"
                     FontFamily="{StaticResource TitleFontFamily}"
                     FontSize="16"
                     FontWeight="Bold"
                     Foreground="{DynamicResource TextPrimaryBrush}" />
          <Border Grid.Column="2" Background="Transparent" />
        </Grid>

        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="0">
          <Button Name="ThemeToggleButton"
                  Classes="TitleBarIconButton"
                  Click="OnThemeToggleButtonClick"
                  ToolTip.Tip="Toggle theme">
            <Grid Width="16" Height="16">
              <Ellipse Width="16" Height="16" StrokeThickness="2" />
              <Canvas Width="16" Height="16">
                <Path Data="M8,2 A6,6 0 0 1 8,14 Z" />
              </Canvas>
            </Grid>
          </Button>
          <Button Name="MinimizeWindowButton"
                  Classes="TitleBarIconButton"
                  Click="OnMinimizeWindowButtonClick"
                  ToolTip.Tip="Minimize">
            <Grid Width="16" Height="16">
              <Rectangle Width="14"
                         Height="2"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Bottom"
                         Margin="0,0,0,2" />
            </Grid>
          </Button>
          <Button Name="MaximizeWindowButton"
                  Classes="TitleBarIconButton"
                  Click="OnMaximizeWindowButtonClick"
                  ToolTip.Tip="Maximize">
            <Viewbox Width="15" Height="15">
              <Path Width="24" Height="24" Stretch="Uniform"
                    Data="M5 5H19V19H5V5ZM7 7V17H17V7H7Z" />
            </Viewbox>
          </Button>
          <Button Name="CloseWindowButton"
                  Classes="TitleBarIconButton TitleBarCloseButton"
                  Click="OnCloseWindowButtonClick"
                  ToolTip.Tip="Close">
            <Viewbox Width="15" Height="15">
              <Path Width="24" Height="24" Stretch="Uniform"
                    Data="M6.4 5L12 10.6L17.6 5L19 6.4L13.4 12L19 17.6L17.6 19L12 13.4L6.4 19L5 17.6L10.6 12L5 6.4L6.4 5Z" />
            </Viewbox>
          </Button>
        </StackPanel>

        <TextBlock Name="Results"
                   Grid.Column="0" Grid.ColumnSpan="2"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   IsHitTestVisible="False"
                   FontFamily="{StaticResource TitleFontFamily}"
                   FontSize="16" FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimaryBrush}" />
      </Grid>
    </Border>

    <DockPanel Grid.Row="1">
    <Border DockPanel.Dock="Bottom" Height="24" Background="{DynamicResource SurfaceBgBrush}" BorderBrush="{DynamicResource ChromeBorderBrush}" BorderThickness="0,1,0,0">
      <Grid ColumnDefinitions="*,Auto,Auto">
        <TextBlock Name="StatusBarText" VerticalAlignment="Center" Margin="6,0,0,0" Text="{Binding StatusText}" TextTrimming="CharacterEllipsis" />
        <TextBlock Name="PositionBarText" Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0"
                   Text="{Binding PositionLabel}"
                   Foreground="{DynamicResource ChromeAccentBrush}"
                   ToolTip.Tip="Active watch test position (NIHS 95-10 / ISO 3158) - pick it on the Positions tab" />
        <TextBlock Name="LatencyBarText" Grid.Column="2" VerticalAlignment="Center" Margin="12,0,6,0"
                   Text="{Binding LatencyText}"
                   ToolTip.Tip="End-to-end latency avg/worst (capture→processing + processing→display), dropped input samples / coalesced UI frames, missed beats, sync losses" />
      </Grid>
    </Border>

    <!-- Pause-and-review bar (above the status bar, only while paused): scrub the
         review cursor through the captured readings without losing any data.
         Maximum binds before Value so the slider never coerces the restored
         cursor against a stale 0..100 default range. -->
    <Border Name="ReviewBar"
            DockPanel.Dock="Bottom" Height="32"
            Background="{DynamicResource SurfaceBgBrush}"
            BorderBrush="{DynamicResource ChromeBorderBrush}"
            BorderThickness="0,1,0,0"
            IsVisible="{Binding IsReviewBarVisible}">
      <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto" Margin="6,0">
        <Button Name="ReviewStepBackButton" Grid.Column="0"
                Content="-1 s" FontSize="11" Padding="8,2"
                VerticalAlignment="Center" Margin="0,0,4,0"
                Command="{Binding ReviewStepBackCommand}"
                ToolTip.Tip="Move the review cursor 1 second back" />
        <Button Name="ReviewStepForwardButton" Grid.Column="1"
                Content="+1 s" FontSize="11" Padding="8,2"
                VerticalAlignment="Center" Margin="0,0,8,0"
                Command="{Binding ReviewStepForwardCommand}"
                ToolTip.Tip="Move the review cursor 1 second forward" />
        <Slider Name="ReviewSlider" Grid.Column="2"
                VerticalAlignment="Center"
                Minimum="0"
                Maximum="{Binding ReviewMaximumS}"
                Value="{Binding ReviewSliderValueS, Mode=TwoWay}"
                ToolTip.Tip="Scrub backward/forward through the captured readings" />
        <Button Name="ReviewLiveButton" Grid.Column="3"
                Content="LIVE" FontSize="11" Padding="8,2"
                VerticalAlignment="Center" Margin="8,0,8,0"
                Command="{Binding ReviewLiveCommand}"
                ToolTip.Tip="Clear the review cursor (back to the newest reading)" />
        <TextBlock Name="ReviewReadoutLabel" Grid.Column="4"
                   VerticalAlignment="Center" MinWidth="130"
                   Text="{Binding ReviewReadoutText}"
                   ToolTip.Tip="Review cursor position / latest captured time" />
      </Grid>
    </Border>

    <Grid ColumnDefinitions="300,Auto,*">
      <ScrollViewer Grid.Column="0"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Disabled"
                    Background="{DynamicResource PanelBgBrush}">
        <StackPanel Margin="8" Spacing="7">
          <Border Background="{DynamicResource PanelBgBrush}" Padding="8,3">
            <StackPanel Spacing="7">
              <TextBlock Name="RunParamLabel"
                         Classes="SectionHeader"
                         Text="Run Parameters" />
              <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                <TextBlock Name="InputDeviceLabel" Grid.Column="0"
                           Margin="0,0,2,0"
                           VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" Text="Input" />
                <ComboBox Name="InputDeviceComboBox" Grid.Column="1"
                          HorizontalAlignment="Stretch"
                          MinWidth="0"
                          IsEnabled="{Binding AreRunParametersEnabled}"
                          ItemsSource="{Binding InputDeviceNames}"
                          SelectedIndex="{Binding SelectedInputDeviceIndex, Mode=TwoWay}"
                          FontWeight="Bold">
                  <ComboBox.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis" MaxWidth="220" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
              </Grid>

              <Grid ColumnDefinitions="98,*" RowDefinitions="32,32,32" RowSpacing="3" ColumnSpacing="8">
                <TextBlock Name="SampleRateLabel" Grid.Row="0" Grid.Column="0"
                           VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" Text="Sample Rate" />
                <Grid Grid.Row="0" Grid.Column="1" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                  <ComboBox Name="SampleRatesComboBox" Grid.Column="0"
                            HorizontalAlignment="Stretch"
                            Height="32"
                            IsEnabled="{Binding IsSampleRateEnabled}"
                            ItemsSource="{Binding SampleRateLabels}"
                            SelectedIndex="{Binding SelectedSampleRateIndex, Mode=TwoWay}"
                            FontWeight="Bold" />

                  <Button Name="RefreshPushButton" Grid.Column="1"
                          Classes="RunIconButton InlineComboIconButton"
                          Command="{Binding RefreshDevicesCommand}"
                          IsEnabled="{Binding AreRunParametersEnabled}"
                          ToolTip.Tip="Refresh input devices">
                    <Viewbox Width="15" Height="15">
                      <Path Width="24" Height="24" Stretch="Uniform"
                            Data="M17.65 6.35C16.2 4.9 14.21 4 12 4C7.58 4 4 7.58 4 12C4 16.42 7.58 20 12 20C15.73 20 18.84 17.45 19.73 14H17.65C16.82 16.33 14.6 18 12 18C8.69 18 6 15.31 6 12C6 8.69 8.69 6 12 6C13.66 6 15.14 6.69 16.22 7.78L13 11H20V4L17.65 6.35Z" />
                    </Viewbox>
                  </Button>
                </Grid>

                <TextBlock Name="GainLabel" Grid.Row="1" Grid.Column="0"
                           VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" Text="Gain" />
                <Slider Name="MicrophoneHorizontalSlider" Grid.Row="1" Grid.Column="1"
                        VerticalAlignment="Center"
                        Height="32"
                        Margin="0,-7,0,7"
                        IsEnabled="{Binding IsGainEnabled}"
                        Minimum="0" Maximum="1000" Value="{Binding Gain, Mode=TwoWay}" Orientation="Horizontal" />

                <TextBlock Name="AveragingPeriodLabel" Grid.Row="2" Grid.Column="0"
                           VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" Text="Avg. Period" />
                <Grid Grid.Row="2" Grid.Column="1" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                  <ComboBox Name="AveragingPeriodComboBox" Grid.Column="0"
                            HorizontalAlignment="Stretch"
                            Height="32"
                            IsEnabled="{Binding AreRunParametersEnabled}"
                            ItemsSource="{Binding AveragingPeriodLabels}"
                            SelectedIndex="{Binding SelectedAveragingPeriodIndex, Mode=TwoWay}"
                            FontWeight="Bold" />

                  <Button Name="StopPushButton" Grid.Column="1"
                          Classes="RunIconButton InlineComboIconButton"
                          Command="{Binding StopCommand}"
                          IsEnabled="{Binding IsStopEnabled}"
                          ToolTip.Tip="Stop">
                    <Viewbox Width="14" Height="14">
                      <Path Width="24" Height="24" Stretch="Uniform"
                            Data="M6 6H18V18H6V6Z" />
                    </Viewbox>
                  </Button>

                  <Button Name="PlayPausePushButton" Grid.Column="2"
                          Classes="RunIconButton InlineComboIconButton PrimaryRunIconButton"
                          Command="{Binding PlayPauseCommand}"
                          IsEnabled="{Binding IsPlayPauseEnabled}"
                          ToolTip.Tip="{Binding PlayPauseButtonText}">
                    <Grid HorizontalAlignment="Center">
                      <Viewbox Width="14" Height="14"
                               IsVisible="{Binding IsPlayPauseButtonShowingPlay}">
                        <Path Width="24" Height="24" Stretch="Uniform"
                              Data="M8 5V19L19 12L8 5Z" />
                      </Viewbox>
                      <Viewbox Width="14" Height="14"
                               IsVisible="{Binding IsPlayPauseButtonShowingPause}">
                        <Path Width="24" Height="24" Stretch="Uniform"
                              Data="M6 5H10V19H6V5ZM14 5H18V19H14V5Z" />
                      </Viewbox>
                    </Grid>
                  </Button>
                </Grid>
              </Grid>
            </StackPanel>
          </Border>

          <Border Height="1" Background="{DynamicResource ChromeBorderBrush}" Margin="12,0" />

          <Border Background="{DynamicResource PanelBgBrush}" Padding="8,3">
            <StackPanel Spacing="7">
              <TextBlock Name="WatchParamLabel"
                         Classes="SectionHeader"
                         Text="Watch Parameters" />
              <Grid ColumnDefinitions="106,*" RowDefinitions="Auto,Auto" RowSpacing="6" ColumnSpacing="8">
                <TextBlock Name="WatchBphLabel" Grid.Row="0" Grid.Column="0"
                           VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" Text="BPH" />
                <ComboBox Name="BPHComboBox" Grid.Row="0" Grid.Column="1"
                          HorizontalAlignment="Stretch"
                          IsEnabled="{Binding AreRunParametersEnabled}"
                          ItemsSource="{Binding BphLabels}"
                          SelectedIndex="{Binding SelectedBphIndex, Mode=TwoWay}"
                          FontWeight="Bold" />

                <TextBlock Name="LiftAngleLabel" Grid.Row="1" Grid.Column="0"
                           VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" Text="Lift Angle" />
                <NumericUpDown Name="LiftAngleSpinBox" Grid.Row="1" Grid.Column="1"
                               IsEnabled="{Binding AreRunParametersEnabled}"
                               Value="{Binding LiftAngle, Mode=TwoWay}"
                               FontWeight="Bold" FormatString="0'°'"
                               Minimum="30" Maximum="70" Increment="1" />
              </Grid>
            </StackPanel>
          </Border>

          <Border Height="1" Background="{DynamicResource ChromeBorderBrush}" Margin="12,0" />

          <Border Background="{DynamicResource PanelBgBrush}" Padding="8,3">
            <StackPanel Spacing="7">
              <TextBlock Name="SimParamLabel"
                         Classes="SectionHeader"
                         Text="Simulation Parameters" />
              <Grid ColumnDefinitions="106,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="6" ColumnSpacing="8">
                <TextBlock Name="SimBphLabel" Grid.Row="0" Grid.Column="0"
                           VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" Text="BPH" />
                <ComboBox Name="SimBPHComboBox" Grid.Row="0" Grid.Column="1"
                          HorizontalAlignment="Stretch"
                          IsEnabled="{Binding AreRunParametersEnabled}"
                          ItemsSource="{Binding SimBphLabels}"
                          SelectedIndex="{Binding SelectedSimBphIndex, Mode=TwoWay}"
                          FontWeight="Bold" />

                <TextBlock Name="SimErrorRateLabel" Grid.Row="1" Grid.Column="0"
                           VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" Text="Error Rate" />
                <NumericUpDown Name="SimErrorRateSpinBox" Grid.Row="1" Grid.Column="1"
                               IsEnabled="{Binding AreRunParametersEnabled}"
                               Value="{Binding SimErrorRate, Mode=TwoWay}"
                               FontWeight="Bold" FormatString="0' s/d'"
                               Minimum="-999" Maximum="999" Increment="1" />

                <TextBlock Name="SimAmpLabel" Grid.Row="2" Grid.Column="0"
                           VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" Text="Amplitude" />
                <NumericUpDown Name="SimAmplitudeSpinBox" Grid.Row="2" Grid.Column="1"
                               IsEnabled="{Binding AreRunParametersEnabled}"
                               Value="{Binding SimAmplitude, Mode=TwoWay}"
                               FontWeight="Bold" FormatString="0'°'"
                               Minimum="100" Maximum="360" Increment="1" />

                <TextBlock Name="SimBeatErrorLabel" Grid.Row="3" Grid.Column="0"
                           VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" Text="Beat Error" />
                <NumericUpDown Name="SimBeatErrorSpinBox" Grid.Row="3" Grid.Column="1"
                               IsEnabled="{Binding AreRunParametersEnabled}"
                               Value="{Binding SimBeatError, Mode=TwoWay}"
                               FontWeight="Bold" FormatString="0.0' ms'"
                               Minimum="-10" Maximum="10" Increment="0.1" />

                <CheckBox Name="RealisticCheckBox" Grid.Row="4" Grid.ColumnSpan="2"
                          HorizontalAlignment="Right"
                          IsEnabled="{Binding AreRunParametersEnabled}"
                          FontWeight="Bold" Content="Realistic" IsChecked="{Binding Realistic, Mode=TwoWay}" />
              </Grid>
            </StackPanel>
          </Border>

          <Border Height="1" Background="{DynamicResource ChromeBorderBrush}" Margin="12,0" />

          <Border Background="{DynamicResource PanelBgBrush}" Padding="8,3">
            <StackPanel Spacing="7">
              <TextBlock Name="MiscLabel"
                         Classes="SectionHeader"
                         Text="Misc. Parameters" />
              <Grid ColumnDefinitions="132,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="6" ColumnSpacing="8">
                <TextBlock Name="HighPassLabel" Grid.Row="0" Grid.Column="0"
                           VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" Text="High Pass Cutoff" />
                <TextBox Name="HighLineEdit" Grid.Row="0" Grid.Column="1"
                         IsEnabled="{Binding AreRunParametersEnabled}"
                         Text="{Binding HighPassCutoffText, Mode=TwoWay}" />

                <TextBlock Name="ScopeScaleLabel" Grid.Row="1" Grid.Column="0"
                           VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" Text="Scope Scale" />
                <NumericUpDown Name="ScopeScaleSpinBox" Grid.Row="1" Grid.Column="1"
                               Minimum="1" Maximum="8" Increment="1"
                               Value="{Binding ScopeScale, Mode=TwoWay}" />

                <CheckBox Name="UseConsetCheckBox" Grid.Row="2" Grid.ColumnSpan="2"
                          HorizontalAlignment="Right"
                          IsEnabled="{Binding AreRunParametersEnabled}"
                          FontWeight="Bold" Content="C Event Use Onset Amplitude"
                          IsChecked="{Binding UseCOnset, Mode=TwoWay}" />
              </Grid>
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>

      <Border Grid.Column="1" Width="1" Margin="0,12"
              Background="{DynamicResource ChromeBorderBrush}" />

      <TabControl Name="GraphicsTabWidget" Grid.Column="2" Margin="8,3,10,10">
        <TabControl.ItemsPanel>
          <ItemsPanelTemplate>
            <UniformGrid Rows="2" />
          </ItemsPanelTemplate>
        </TabControl.ItemsPanel>
      </TabControl>
    </Grid>
    </DockPanel>
  </Grid>
</Window>
