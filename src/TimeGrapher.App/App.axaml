<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="TimeGrapher.App.App"
             RequestedThemeVariant="Light">
  <Application.Resources>
    <ResourceDictionary>
      <FontFamily x:Key="AppFontFamily">avares://TimeGrapher.App/Assets/Fonts/D2Coding#D2Coding</FontFamily>
      <FontFamily x:Key="TitleFontFamily">avares://TimeGrapher.App/Assets/Fonts/Hack#Hack</FontFamily>
      <CornerRadius x:Key="ControlCornerRadius">0</CornerRadius>
      <CornerRadius x:Key="OverlayCornerRadius">0</CornerRadius>

      <!--
        Single source of truth for every theme color (UI chrome AND scope graphs).
        Define each color once here; brushes derive from these Color keys, and the
        graph renderer reads the same keys via PlotThemePalette.FromResources.
        To recolor the app, edit only this block.
      -->
      <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
          <Color x:Key="SurfaceColor">#E2E3E4</Color>
          <Color x:Key="PanelColor">#E2E3E4</Color>
          <Color x:Key="TextPrimaryColor">#1A1A1A</Color>
          <Color x:Key="ChromeBorderColor">#CFCFCF</Color>
          <Color x:Key="ChromeAccentColor">#C41230</Color>
          <Color x:Key="ScopeBgColor">#FFFFFF</Color>
          <Color x:Key="ScopeGridColor">#EAEAEA</Color>
          <Color x:Key="TraceWaveColor">#6B6B6B</Color>
          <Color x:Key="TraceTickColor">#2C9118</Color>
          <Color x:Key="TraceTockColor">#D22222</Color>

          <SolidColorBrush x:Key="SurfaceBgBrush" Color="{DynamicResource SurfaceColor}" />
          <SolidColorBrush x:Key="PanelBgBrush" Color="{DynamicResource PanelColor}" />
          <SolidColorBrush x:Key="ScopeBgBrush" Color="{DynamicResource ScopeBgColor}" />
          <SolidColorBrush x:Key="TextPrimaryBrush" Color="{DynamicResource TextPrimaryColor}" />
          <SolidColorBrush x:Key="ChromeBorderBrush" Color="{DynamicResource ChromeBorderColor}" />
          <SolidColorBrush x:Key="ChromeAccentBrush" Color="{DynamicResource ChromeAccentColor}" />

          <!-- Selected tab text: pure black in light theme. -->
          <SolidColorBrush x:Key="TabItemHeaderForegroundSelected" Color="#000000" />
          <SolidColorBrush x:Key="TabItemHeaderForegroundSelectedPointerOver" Color="#000000" />
          <SolidColorBrush x:Key="TabItemHeaderForegroundSelectedPressed" Color="#000000" />
        </ResourceDictionary>

        <ResourceDictionary x:Key="Dark">
          <Color x:Key="SurfaceColor">#1D1D1B</Color>
          <Color x:Key="PanelColor">#1D1D1B</Color>
          <Color x:Key="TextPrimaryColor">#C2C8CE</Color>
          <Color x:Key="ChromeBorderColor">#333333</Color>
          <Color x:Key="ChromeAccentColor">#A50034</Color>
          <Color x:Key="ScopeBgColor">#000000</Color>
          <Color x:Key="ScopeGridColor">#1A1A1A</Color>
          <Color x:Key="TraceWaveColor">#A0A0A0</Color>
          <Color x:Key="TraceTickColor">#5FDD45</Color>
          <Color x:Key="TraceTockColor">#FF5C5C</Color>

          <SolidColorBrush x:Key="SurfaceBgBrush" Color="{DynamicResource SurfaceColor}" />
          <SolidColorBrush x:Key="PanelBgBrush" Color="{DynamicResource PanelColor}" />
          <SolidColorBrush x:Key="ScopeBgBrush" Color="{DynamicResource ScopeBgColor}" />
          <SolidColorBrush x:Key="TextPrimaryBrush" Color="{DynamicResource TextPrimaryColor}" />
          <SolidColorBrush x:Key="ChromeBorderBrush" Color="{DynamicResource ChromeBorderColor}" />
          <SolidColorBrush x:Key="ChromeAccentBrush" Color="{DynamicResource ChromeAccentColor}" />

          <!-- Selected tab text: pure white in dark theme. -->
          <SolidColorBrush x:Key="TabItemHeaderForegroundSelected" Color="#FFFFFF" />
          <SolidColorBrush x:Key="TabItemHeaderForegroundSelectedPointerOver" Color="#FFFFFF" />
          <SolidColorBrush x:Key="TabItemHeaderForegroundSelectedPressed" Color="#FFFFFF" />
        </ResourceDictionary>
      </ResourceDictionary.ThemeDictionaries>
    </ResourceDictionary>
  </Application.Resources>

  <Application.Styles>
    <FluentTheme>
      <FluentTheme.Palettes>
        <ColorPaletteResources x:Key="Light" Accent="#C41230" />
        <ColorPaletteResources x:Key="Dark" Accent="#A50034" />
      </FluentTheme.Palettes>
    </FluentTheme>
    <Style Selector="Window">
      <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="FontSize" Value="14" />
    </Style>
    <Style Selector="Control">
      <Setter Property="TextElement.FontFamily" Value="{StaticResource AppFontFamily}" />
      <Setter Property="TextElement.FontWeight" Value="Bold" />
      <Setter Property="TextElement.FontSize" Value="14" />
    </Style>
    <Style Selector="TemplatedControl">
      <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="CornerRadius" Value="0" />
    </Style>
    <Style Selector="Border">
      <Setter Property="CornerRadius" Value="0" />
    </Style>
    <Style Selector="Thumb">
      <Setter Property="CornerRadius" Value="0" />
    </Style>
    <Style Selector="Button">
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="TabItem">
      <Setter Property="FontFamily" Value="{StaticResource TitleFontFamily}" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="MinHeight" Value="0" />
      <Setter Property="Padding" Value="6,4" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="TabItem:selected">
      <Setter Property="FontWeight" Value="Bold" />
    </Style>
    <Style Selector="TabItem:selected /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="TextElement.FontWeight" Value="Bold" />
    </Style>
    <Style Selector="Button.TitleBarIconButton">
      <Setter Property="Width" Value="46" />
      <Setter Property="Height" Value="36" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.TitleBarIconButton Path">
      <Setter Property="Fill" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>
    <Style Selector="Button.TitleBarIconButton Ellipse">
      <Setter Property="Stroke" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>
    <Style Selector="Button.TitleBarIconButton Rectangle">
      <Setter Property="Fill" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>
    <Style Selector="Button.TitleBarCloseButton">
      <Setter Property="Background" Value="{DynamicResource ChromeAccentBrush}" />
      <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="Button.TitleBarCloseButton Path">
      <Setter Property="Fill" Value="White" />
    </Style>
    <Style Selector="Button.RunIconButton">
      <Setter Property="Width" Value="34" />
      <Setter Property="Height" Value="28" />
      <Setter Property="MinWidth" Value="34" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.InlineComboIconButton">
      <Setter Property="Width" Value="34" />
      <Setter Property="Height" Value="32" />
      <Setter Property="MinWidth" Value="34" />
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="Padding" Value="0" />
    </Style>
    <Style Selector="Button.RunIconButton:disabled">
      <Setter Property="Opacity" Value="0.55" />
    </Style>
    <Style Selector="Button.RunIconButton Path">
      <Setter Property="Fill" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>
    <Style Selector="Button.PrimaryRunIconButton">
      <Setter Property="Background" Value="{DynamicResource ChromeAccentBrush}" />
      <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="Button.PrimaryRunIconButton Path">
      <Setter Property="Fill" Value="White" />
    </Style>
    <Style Selector="TextBlock.SectionHeader">
      <Setter Property="FontFamily" Value="{StaticResource TitleFontFamily}" />
      <Setter Property="FontSize" Value="16" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Foreground" Value="{DynamicResource ChromeAccentBrush}" />
      <Setter Property="TextAlignment" Value="Center" />
    </Style>
    <Style Selector="Slider /template/ Thumb">
      <Setter Property="Width" Value="6" />
      <Setter Property="Height" Value="18" />
      <Setter Property="MinWidth" Value="6" />
      <Setter Property="MaxWidth" Value="6" />
      <Setter Property="MinHeight" Value="18" />
      <Setter Property="MaxHeight" Value="18" />
      <Setter Property="Background" Value="{DynamicResource ChromeAccentBrush}" />
      <Setter Property="CornerRadius" Value="0" />
      <Setter Property="Template">
        <ControlTemplate>
          <Border Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="0" />
        </ControlTemplate>
      </Setter>
    </Style>
    <Style Selector="Slider /template/ Thumb /template/ Border">
      <Setter Property="CornerRadius" Value="0" />
    </Style>
    <Style Selector="CheckBox /template/ Border">
      <Setter Property="CornerRadius" Value="0" />
    </Style>
    <Style Selector="TextBlock">
      <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>
    <!-- Positions tab: the active position button (declared after the
         global TextBlock style so the white-on-accent text wins). -->
    <Style Selector="Button.PositionButton">
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.PositionButton.active">
      <Setter Property="Background" Value="{DynamicResource ChromeAccentBrush}" />
    </Style>
    <Style Selector="Button.PositionButton.active TextBlock">
      <Setter Property="Foreground" Value="White" />
    </Style>
    <!-- Positions tab: accent highlight behind the table row of
         the position currently being measured, with white-on-accent cell text
         (declared after the global TextBlock style so the override wins). -->
    <Style Selector="Border.SeqActiveRow">
      <Setter Property="Background" Value="{DynamicResource ChromeAccentBrush}" />
    </Style>
    <Style Selector="TextBlock.SeqOnAccent">
      <Setter Property="Foreground" Value="White" />
    </Style>
  </Application.Styles>
</Application>
